# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
# Use Test Mode keys while developing.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key_here

# Optional: expose key id to frontend (same as RAZORPAY_KEY_ID)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Payment API port (default 3001)
PORT=3001

# Production: URL of your deployed payment API (leave empty for local dev proxy)
# VITE_API_URL=https://your-api.example.com
